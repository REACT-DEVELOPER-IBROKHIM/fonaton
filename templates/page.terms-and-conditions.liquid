{%- render 'stylesheet', name: 'common' -%}

{% assign page_title = page.title %}

<style>
  .container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 var(--default-padding);
  }

  .terms-container {
    max-width: 900px;
    margin: 60px auto;
    padding: 0 var(--default-padding);
    font-family: var(--font-family-Roboto), -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
    line-height: 1.8;
    color: var(--color-grey);
  }

  .terms-header {
    text-align: center;
    margin-bottom: 60px;
    border-bottom: 2px solid #e0e0e0;
    padding-bottom: 30px;
  }

  .terms-header h1 {
    font-size: 2.5rem;
    margin: 0 0 10px 0;
    color: var(--color-black);
    font-weight: 700;
    line-height: 1.2;
  }

  .terms-header p {
    font-size: 0.95rem;
    color: var(--color-grey);
    margin: 0;
  }

  .terms-section {
    margin-bottom: 50px;
  }

  .terms-section h2 {
    font-size: 1.5rem;
    color: var(--color-black);
    margin: 40px 0 20px 0;
    padding-bottom: 10px;
    border-bottom: 2px solid #f0f0f0;
    font-weight: 600;
    line-height: 1.3;
  }

  .terms-section h3 {
    font-size: 1.1rem;
    color: var(--color-grey);
    margin: 25px 0 15px 0;
    font-weight: 600;
  }

  .terms-section p {
    margin: 15px 0;
    line-height: 1.8;
    color: var(--color-grey);
  }

  .terms-section ul {
    margin: 15px 0;
    padding-left: 25px;
  }

  .terms-section li {
    margin: 10px 0;
    color: var(--color-grey);
  }

  .terms-footer {
    margin-top: 60px;
    padding-top: 30px;
    border-top: 2px solid #e0e0e0;
    text-align: center;
    color: var(--color-grey);
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .terms-container {
      margin: 40px auto;
      padding: 0 var(--tablet-padding);
    }

    .terms-header h1 {
      font-size: 1.8rem;
    }

    .terms-section h2 {
      font-size: 1.3rem;
    }
  }

  @media (max-width: 480px) {
    .terms-container {
      padding: 0 var(--mobile-padding);
    }

    .terms-header h1 {
      font-size: 1.5rem;
    }

    .terms-section h2 {
      font-size: 1.1rem;
    }
  }
</style>

{%- section 'navigation' -%}


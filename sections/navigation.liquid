{%- render 'stylesheet', name: 'navigation' -%}
{%- render 'tag-script', name: 'navigation', loading: 'defer' -%}

<nav
  id="#navigation"
  class="section-navigation {% if request.page_type != 'index' %}default-navbar{% endif %}"
  role="navigation"
  aria-label="Site navigation">
  <div class="container">
    <div class="navigation__wrapper">
      <h1 class="visually-hidden">FONATON</h1>
      <a href="{{ routes.root_url }}">
        {% if settings.logo_light and settings.logo_dark %}
        <div class='navigation__logo--light'>
          {{ settings.logo_light | image_url: width: 150 | image_tag: alt: settings.logo_alt_text }}
        </div>
        <div class='navigation__logo--dark'>
          {{ settings.logo_dark | image_url: width: 150 | image_tag: alt: settings.logo_alt_text }}
        </div>
      {% endif %}
      </a>

      <button class="navigation__hamburger" aria-label="Toggle menu" aria-expanded="false">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>

      <ul class="navigation__menu">
        {% for link in linklists.main-menu.links %}
          <li class="navigation__menu-item">
            {% if link.links != blank %}
              <a class="navigation__menu-link">
              {{ link.title }}
            </a>
            {% else %}
               <a href="{{ link.url }}" class="navigation__menu-link">
              {{ link.title }}
            </a>
            {% endif %}
              {% if link.links != blank %}
                  {% render 'chevron-down' %}
              {% endif %}</a>
            {%- if link.links != blank -%}
              <div class="submenu-wrapper">
                <div class="container">
                  <ul class="submenu">
                    {%- for child_link in link.links -%}
                      <li role="listitem" class="submenu-item">
                        <a
                          role="link"
                          class="submenu-item__link"
                          href="{{ child_link.url }}"
                          {% if child_link.active %}aria-current="page"{% endif %}>
                          <span class="submenu-item__icon">
                            {%- case forloop.index -%}
                              {%- when 1 -%}
                                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3v5z"/><path d="M3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3v5z"/></svg>
                              {%- when 2 -%}
                                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><path d="m3.27 6.96 8.73 5.05 8.73-5.05"/><path d="M12 22.08V12"/></svg>
                              {%- when 3 -%}
                                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10"/><path d="M12 8v8"/><path d="M8 12h8"/></svg>
                              {%- when 4 -%}
                                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="16" height="10" x="2" y="7" rx="2" ry="2"/><line x1="22" x2="22" y1="11" y2="13"/></svg>
                              {%- else -%}
                                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9A1 1 0 0 0 21.4 6Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/></svg>
                            {%- endcase -%}
                          </span>
                          <span class="submenu-item__label">{{ child_link.title }}</span>
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                </div>
              </div>
            {%- endif -%}
          </li>
        {% endfor %}
      </ul>
      
      {% render 'lang-select' %}
    </div>
  </div>
</nav>

{% schema %}
  {
    "name": "Navigation",
    "settings": [],
    "blocks": [],
    "presets": [
      {
        "name": "Navigation",
        "category": "Header"
      }
    ]
  }
{% endschema %}
{%- render 'stylesheet', name: 'list-collections' -%}

<section class="section-list-collections">
  <div class="container">
    {%- render 'breadcrumb' -%}

    <div class="list-collections__header" data-animate="fade-up">
      {% if section.settings.title != blank %}
        <h1 class="list-collections__title">{{ section.settings.title }}</h1>
      {% else %}
        <h1 class="list-collections__title">{{ 'list_collections.title' | t }}</h1>
      {% endif %}

      {% if section.settings.subtitle != blank %}
        <p class="list-collections__subtitle">{{ section.settings.subtitle }}</p>
      {% else %}
        <p class="list-collections__subtitle">{{ 'list_collections.subtitle' | t }}</p>
      {% endif %}
    </div>

    {%- liquid
      assign hidden_handles = 'frontpage'
      for col in section.settings.hidden_collections
        assign hidden_handles = hidden_handles | append: ',' | append: col.handle
      endfor
    -%}

    <div class="list-collections__grid">
      {% for collection in collections %}
        {% unless hidden_handles contains collection.handle %}
          <div class="collection-card" data-animate="scale-up" style="--animate-delay: {{ forloop.index0 | times: 80 | at_most: 480 }}ms">
            <a href="{{ collection.url }}" class="collection-card__link" aria-label="{{ collection.title }}">
              <div class="collection-card__image-wrapper">
                {% if collection.featured_image %}
                  {{ collection.featured_image | image_url: width: 600 | image_tag: alt: collection.title, class: 'collection-card__image', loading: 'lazy' }}
                {% else %}
                  <div class="collection-card__placeholder">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
                      <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                      <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                      <line x1="12" y1="22.08" x2="12" y2="12"/>
                    </svg>
                  </div>
                {% endif %}
              </div>

              <div class="collection-card__body">
                <h2 class="collection-card__name">{{ collection.title }}</h2>

                {% if collection.description != blank %}
                  <p class="collection-card__description">{{ collection.description | strip_html | truncatewords: 18 }}</p>
                {% endif %}

                {% if collection.products_count > 0 %}
                  <p class="collection-card__count">{{ collection.products_count }} {{ 'list_collections.products' | t }}</p>
                {% endif %}

                <span class="collection-card__cta">{{ 'list_collections.shop_now' | t }}</span>
              </div>
            </a>
          </div>
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "List Collections",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Page Title"
      },
      {
        "type": "textarea",
        "id": "subtitle",
        "label": "Page Subtitle"
      },
      {
        "type": "collection_list",
        "id": "hidden_collections",
        "label": "Hidden Collections",
        "info": "Collections selected here will not appear on this page."
      }
    ],
    "presets": [
      {
        "name": "List Collections",
        "category": "Collections"
      }
    ]
  }
{% endschema %}

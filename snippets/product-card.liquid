{%- render 'stylesheet', name: 'product-card' -%}

  <div class="product">
          <div class="product-tag-header">
            {% if product.tags.size > 0 %}
              <div class="product-tags">
                {% for tag in product.tags %}
                  {% if tag != "featured" %}
                    <p class="product-tag {{ tag }}">{{ tag }}</p>
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}
          </div>
          <a href="{{ product.url }}" class="product__link">
            <div class="product__image-container">
              <img
                src="{{ product.featured_image | img_url: 'medium' }}"
                alt="{{ product.title }}"
                class="product__image" />
            </div>
          </a>
          <h3 class="product__title">{{ product.title }}</h3>
          {% if product.description %}
            <div class="product__description">
              {{ product.description | strip_html | truncatewords: 12 }}
            </div>
          {% endif %}
          {% if product.price > 0 %}
            <div class="product__prices">
              {% if product.compare_at_price %}
                <p class="product__original-price">{{ product.compare_at_price | money }}</p>
              {% endif %}
              <p class="product__sale-price">{{ product.price | money }}</p>
              {% if product.compare_at_price %}
                <div class="product-discount-percentage">
                  {{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price | floor | prepend: '-' }}%
                </div>
              {% endif %}
            </div>
          {% endif %}
          <a href="{{ product.url }}" class="product__caa">
            More Details
          </a>
        </div>